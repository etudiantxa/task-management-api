# Database Configuration
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DATABASE_NAME=task_management_db

# For SQLite specifically
DB_STORAGE=.db/data.sqlite3

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_generate_strong_one

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Google OAuth Client (use environment variables for production)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application Configuration
PORT=3000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,https://yourdomain.com